             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["i", "TI"]]}]]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "\\frac{\\partial}{\\partial x_k}\\frac{\\partial}{\\partial \
x_j}\\frac{\\partial G}{\\partial x_i}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"],
    TraditionalForm]}]}]], "Text",
