Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"\[ImaginaryJ]", " ", "k", " ", "r"}], "]"}], 
    RowBox[{"4", " ", "\[Pi]", " ", "r"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.966499333036209*^9, 3.966499337399693*^9}, {
   3.966499424454275*^9, 3.9664994353777237`*^9}, 3.966499481206682*^9},
