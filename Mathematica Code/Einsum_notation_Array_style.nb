Cell[TextData[{
 "Therefore, we can conclude ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["j", "TI"], 
          StyleBox["k", "TI"], 
          FractionBox[
           RowBox[{"\[PartialD]", 
             SuperscriptBox[
              StyleBox["r", "TI"], "-3"], 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["i", "TI"]], 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["j", "TI"]], 
             StyleBox["G", "TI"]}], 
           RowBox[{"\[PartialD]", 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["k", "TI"]]}]], "\[LongEqual]", 
          StyleBox["j", "TI"], 
          StyleBox["k", "TI"], 
          RowBox[{"(", 
            RowBox[{"-4", 
              SuperscriptBox[
               StyleBox["r", "TI"], "-5"], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["i", "TI"]], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["j", "TI"]], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["k", "TI"]], 
              StyleBox["G", "TI"], "+", 
              SuperscriptBox[
               StyleBox["r", "TI"], "-3"], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["j", "TI"]], 
              SubscriptBox["\[Delta]", 
               RowBox[{
                 StyleBox["i", "TI"], 
                 StyleBox["k", "TI"]}]], 
              StyleBox["G", "TI"], "+", 
              SuperscriptBox[
               StyleBox["r", "TI"], "-3"], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["i", "TI"]], 
              SubscriptBox["\[Delta]", 
               RowBox[{
                 StyleBox["j", "TI"], 
                 StyleBox["k", "TI"]}]], 
              StyleBox["G", "TI"], "+", 
              StyleBox["j", "TI"], 
              StyleBox["k", "TI"], 
              SuperscriptBox[
               StyleBox["r", "TI"], "-4"], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["i", "TI"]], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["j", "TI"]], 
              SubscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["k", "TI"]], 
              StyleBox["G", "TI"]}], ")"}]}], TraditionalForm], 
      "errors" -> {}, "input" -> 
      "jk \\frac{\\partial r^{-3}x_i x_j G}{\\partial x_k}=jk(-4r^{-5}x_i x_j \
x_k G + r^{-3} x_j \\delta_{ik} G + r^{-3}x_i \\delta_{jk}G + \
jkr^{-4}x_ix_jx_k G)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "b115245e-3eb7-4adf-afc5-884446299aaa"],
 ". Should be aware reusing the letter \[OpenCurlyDoubleQuote]k\
\[CloseCurlyDoubleQuote] is probably not a good idea for Mathematica. "
}], "Text",
 CellChangeTimes->{
  3.96658700773239*^9, {3.966587102356305*^9, 3.9665871059183817`*^9}, {
