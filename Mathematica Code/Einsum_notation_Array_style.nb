Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"G", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"\[ImaginaryI]", " ", "k", " ", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["x", "2"], "+", 
                SuperscriptBox["y", "2"], "+", 
                SuperscriptBox["z", "2"]}]]}]], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox["y", "2"], "+", 
                 SuperscriptBox["z", "2"]}], ")"}], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"-", "1"}], "+", 
                 RowBox[{
                  SuperscriptBox["k", "2"], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    SuperscriptBox["y", "2"], "+", 
                    SuperscriptBox["z", "2"]}], ")"}]}], "+", 
                 RowBox[{"\[ImaginaryI]", " ", "k", " ", 
                  SqrtBox[
                   RowBox[{
                    SuperscriptBox["x", "2"], "+", 
                    SuperscriptBox["y", "2"], "+", 
                    SuperscriptBox["z", "2"]}]]}]}], ")"}]}], "+", 
              RowBox[{
               SuperscriptBox["x", "2"], " ", 
               RowBox[{"(", 
                RowBox[{"2", "+", 
                 RowBox[{
                  SuperscriptBox["k", "2"], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    SuperscriptBox["y", "2"], "+", 
                    SuperscriptBox["z", "2"]}], ")"}]}], "-", 
                 RowBox[{"2", " ", "\[ImaginaryI]", " ", "k", " ", 
                  SqrtBox[
                   RowBox[{
                    SuperscriptBox["x", "2"], "+", 
                    SuperscriptBox["y", "2"], "+", 
                    SuperscriptBox["z", "2"]}]]}]}], ")"}]}]}], ")"}]}], 
           ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"4", " ", "\[Pi]", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["x", "2"], "+", 
               SuperscriptBox["y", "2"], "+", 
               SuperscriptBox["z", "2"]}], ")"}], 
             RowBox[{"5", "/", "2"}]], " ", "\[Epsilon]0", " ", 
            "\[Epsilon]b"}], ")"}]}], ",", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{"\[ImaginaryI]", " ", "k", " ", 
                SqrtBox[
                 RowBox[{
                  SuperscriptBox["x", "2"], "+", 
                  SuperscriptBox["y", "2"], "+", 
                  SuperscriptBox["z", "2"]}]]}]], " ", "x", " ", "y", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "3"}], "+", 
                RowBox[{"3", " ", "\[ImaginaryI]", " ", "k", " ", 
                 SqrtBox[
                  RowBox[{
                   SuperscriptBox["x", "2"], "+", 
                   SuperscriptBox["y", "2"], "+", 
                   SuperscriptBox["z", "2"]}]]}], "+", 
                RowBox[{
                 SuperscriptBox["k", "2"], " ", 
                 RowBox[{"(", 
                  RowBox[{
                   SuperscriptBox["x", "2"], "+", 
                   SuperscriptBox["y", "2"], "+", 
                   SuperscriptBox["z", "2"]}], ")"}]}]}], ")"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"4", " ", "\[Pi]", " ", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox["x", "2"], "+", 
                 SuperscriptBox["y", "2"], "+", 
                 SuperscriptBox["z", "2"]}], ")"}], 
               RowBox[{"5", "/", "2"}]], " ", "\[Epsilon]0", " ", 
              "\[Epsilon]b"}], ")"}]}], ")"}]}], ",", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{"\[ImaginaryI]", " ", "k", " ", 
                SqrtBox[
                 RowBox[{
                  SuperscriptBox["x", "2"], "+", 
                  SuperscriptBox["y", "2"], "+", 
                  SuperscriptBox["z", "2"]}]]}]], " ", "x", " ", "z", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "3"}], "+", 
                RowBox[{"3", " ", "\[ImaginaryI]", " ", "k", " ", 
                 SqrtBox[
