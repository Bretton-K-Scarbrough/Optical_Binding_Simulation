Cell[TextData[{
 "Therefore, we can conclude that  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["j", "TI"]]}]], 
         FractionBox[
          RowBox[{"\[PartialD]", 
            StyleBox["G", "TI"]}], 
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["i", "TI"]]}]], "\[LongEqual]", 
         StyleBox["G", "TI"], 
         RowBox[{"[", 
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 StyleBox["j", "TI"], 
                 StyleBox["k", "TI"], 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-1"], "-", 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-2"]}], ")"}], 
             SubscriptBox["\[Delta]", 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["j", "TI"]}]], "+", 
             RowBox[{"(", 
               RowBox[{"3", 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-4"], "-", 
                 SuperscriptBox[
                  StyleBox["k", "TI"], "2"], 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-2"], "-", "3", 
                 StyleBox["j", "TI"], 
                 StyleBox["k", "TI"], 
                 SuperscriptBox[
                  StyleBox["r", "TI"], "-3"]}], ")"}], 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["i", "TI"]], 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["j", "TI"]]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{\\partial}{\\partial x_j}\\frac{\\partial G}{\\partial x_i} = \
G[(jkr^{-1}-r^{-2})\\delta_{ij} + (3r^{-4}-k^2r^{-2}-3jkr^{-3})x_ix_j]", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]], "Text",
  CellChangeTimes->{{3.966537663153077*^9, 3.966537664929809*^9}, {
   3.966540953075266*^9, 3.966540960635499*^9}},ExpressionUUID->
  "6064763b-93da-4f19-860b-f9da5b636f04"],
 " (This is \[OpenCurlyDoubleQuote]simplified\[CloseCurlyDoubleQuote] i.e. \
not identical to the one used in the code)"
}], "Text",
 CellChangeTimes->{{3.966540940180736*^9, 3.9665409665188093`*^9}, {
  3.9665410481220627`*^9, 3.966541068777051*^9}, {3.9665462914329348`*^9, 
  3.966546292325018*^9}},ExpressionUUID->"661878c1-101e-43ed-8cc6-\
958f51fc1063"],

Cell["\<\
We can go one step further in checking our results by comparing it with the \
dyadic Green\[CloseCurlyQuote]s function used in the original Mathematica \
simulation which we labeled as \[OpenCurlyDoubleQuote]G\
\[CloseCurlyDoubleQuote] earlier in the code (as apposed to the scalar greens \
function \[OpenCurlyDoubleQuote]g\[CloseCurlyDoubleQuote] in this notebook).\
\>", "Text",
 CellChangeTimes->{{3.9665965838117037`*^9, 3.966596613984846*^9}, {
  3.966596672116849*^9, 
  3.966596697059168*^9}},ExpressionUUID->"bafc18e2-db6b-40fb-9a84-\
e21e8abd6af1"],

