Cell[BoxData[
 RowBox[{
  RowBox[{"gdyad", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["k", "2"], 
           RowBox[{"\[Delta]", "[", 
            RowBox[{"i", ",", "j"}], "]"}], "g"}], " ", "+", " ", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"g", ",", 
              RowBox[{"x", "[", "i", "]"}]}], "]"}], ",", 
            RowBox[{"x", "[", "j", "]"}]}], "]"}]}], ")"}], 
        RowBox[{"\[Epsilon]0", " ", "\[Epsilon]b"}]], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], "//", "Simplify"}],
     "//", "MatrixForm"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.966499498259033*^9, 3.9664995900100203`*^9}, {
   3.96649962450607*^9, 3.96649962695909*^9}, {3.966500049231463*^9, 
