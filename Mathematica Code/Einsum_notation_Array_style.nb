Cell[BoxData[
 RowBox[{
  RowBox[{
  "Using", "  ", "all", " ", "of", " ", "the", " ", "above", " ", 
   "calculations", " ", "and", " ", "the", " ", 
   RowBox[{"equation", ":", " ", 
    FormBox[
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           FractionBox["\[PartialD]", 
            RowBox[{"\[PartialD]", 
              SubscriptBox[
               StyleBox["x", "TI"], 
