 RowBox[{
  RowBox[{"sanityCheck", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["k", "2"], " ", 
          RowBox[{"\[Delta]", "[", 
           RowBox[{"i", ",", "j"}], "]"}], "g"}], " ", "+", " ", "handCalc"}], 
        RowBox[{"\[Epsilon]0", " ", "\[Epsilon]b"}]], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], "//", "Simplify"}],
     "//", "MatrixForm"}]}], ";"}]], "Input",
