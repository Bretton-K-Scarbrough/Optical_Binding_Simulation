Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"r", "=", " ", 
  SqrtBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"i", "=", "1"}], "3"], 
    RowBox[{
     RowBox[{"x", "[", "i", "]"}], 
     RowBox[{"x", "[", "i", "]"}]}]}]]}]], "Input",
 CellChangeTimes->{{3.966499302867313*^9, 3.9664993232026997`*^9}},
