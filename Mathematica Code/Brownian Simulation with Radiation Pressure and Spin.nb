       RowBox[{"[", 
        RowBox[{"i", ";;", 
         RowBox[{"i", "+", "2"}]}], "]"}], "]"}], ".", 
      RowBox[{
       RowBox[{"cPPP", "[", "st", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"i", ";;", 
         RowBox[{"i", "+", "2"}]}], "]"}], "]"}]}], ")"}]}], 
   "]"}]}]}], "Input",
