Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dip", "[", "st_", "]"}], "[", "i_", "]"}], ":=", 
  RowBox[{
   RowBox[{"PPP", "[", "st", "]"}], "[", 
   RowBox[{"[", 
