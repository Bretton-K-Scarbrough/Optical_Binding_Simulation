     RowBox[{"i", "+", "2"}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cdip", "[", "st_", "]"}], "[", "i_", "]"}], ":=", 
  RowBox[{
   RowBox[{"cPPP", "[", "st", "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"i", ";;", 
     RowBox[{"i", "+", "2"}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"absdip", "[", "st_", "]"}], "[", "i_", "]"}], ":=", 
  RowBox[{"Chop", "[", 
   RowBox[{"\[Sqrt]", 
    RowBox[{"(", 
