Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FspinX", "[", "step_", "]"}], "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    FractionBox["1", "8"], "  ", 
    FractionBox["\[Alpha]i", "\[ImaginaryI]"], 
    RowBox[{
     RowBox[{"Curl", "[", 
      RowBox[{"Cross", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"ES", "[", "step", "]"}], "[", "n", "]"}], "[", 
           RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
          RowBox[{"EEinc", "[", 
           RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ")"}], ",", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"cES", "[", "step", "]"}], "[", "n", "]"}], "[", 
           RowBox[{"x", ",", "y", ",", "z"}], "]"}], "+", 
          RowBox[{"cEEinc", "[", 
           RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ")"}]}], "]"}], "]"}], 
     ".", "xx"}]}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      RowBox[{
       RowBox[{"X", "[", "step", "]"}], "[", "n", "]"}]}], ",", 
     RowBox[{"y", "\[Rule]", 
      RowBox[{
       RowBox[{"Y", "[", "step", "]"}], "[", "n", "]"}]}], ",", 
     RowBox[{"z", "\[Rule]", 
      RowBox[{
       RowBox[{"Z", "[", "step", "]"}], "[", "n", "]"}]}]}], 
    "}"}]}]}]], "Input",
 CellChangeTimes->{{3.97938300061145*^9, 3.97938300681083*^9}, {
  3.9793831854935966`*^9, 3.979383225708903*^9}, {3.9793832821646447`*^9, 
